NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skillswap_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT
JWT_ACCESS_SECRET=skillswap_access_secret_key_change_in_production
JWT_REFRESH_SECRET=skillswap_refresh_secret_key_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (use Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="SkillSwap <your_gmail@gmail.com>"

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Upload
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880
